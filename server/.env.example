# ── Server Configuration ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB (REQUIRED) ─────────────────────────────────────────────────────────
# MongoDB Atlas / Local connection URI
MONGODB_URI=mongodb://localhost:27017/cursor_room

# ── JWT Secret (REQUIRED in production) ─────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── CORS Allowed Origins ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In production, set to your Vercel frontend URL(s)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Cloudinary (for production file uploads) ────────────────────────────────────
# Required if you want file uploads to work in production.
# If not configured, the server will use local disk storage (dev only).
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Agora (for voice call) ─────────────────────────────────────────────────────
# Get these from https://console.agora.io
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
